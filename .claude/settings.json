{
  "model": "claude-sonnet-4-6",
  "autoCompact": true,
  "compactThreshold": 0.85,
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git diff --stat > /tmp/gmao-precompact.txt && git status --short >> /tmp/gmao-precompact.txt"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Branch: $(git branch --show-current)\" && echo \"Último commit: $(git log -1 --oneline)\""
          }
        ]
      }
    ]
  }
}
